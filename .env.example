# ran_system — environment variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Database connection (used by both stages) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_psql_database
DB_USER=postgres
# Required — no default. The generators will fail to start if this is empty.
DB_PASSWORD=your_password_here

# ── gpo_synthetic generation parameters ──────────────────────────────────────
# Source table override (defaults: public.dim_individual). Uncomment to change.
# RAN_SOURCE_SCHEMA=public
# RAN_SOURCE_TABLE=dim_individual

RAN_NUM_ROWS=1154
RAN_MATCH_RATIO=0.56
RAN_DUPLICATE_RATIO=0.10
RAN_DOC_OVERLAP_RATIO=0.78
GPO_OUTPUT_PATH=./output/gpo_synthetic_origin.xlsx
RAN_RANDOM_SEED=42
